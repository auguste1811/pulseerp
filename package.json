    "vercel-build": "prisma generate && next build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.10.0",
    "@prisma/client": "6.18.0",
    "bcryptjs": "3.0.2",
    "jose": "6.1.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.30",
    "pg": "8.16.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/pg": "8.15.5",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "prisma": "6.18.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "packageManager": "npm@10.9.2"
