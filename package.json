{
  "name": "pulseerp",
  "version": "2.2.1",
  "private": true,
  "engines": {
    "node": ">=20 <27"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "setup": "npm run db:migrate && npm run db:seed",
    "auth:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('base64url'))\""
  },
  "dependencies": {
    "bcryptjs": "3.0.2",
    "jose": "6.1.0",
    "next": "16.2.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "4.1.12",
    "pg": "8.16.3",
    "@prisma/client": "6.18.0",
    "next-auth": "5.0.0-beta.30",
    "@auth/prisma-adapter": "2.10.0"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "@types/pg": "8.15.5",
    "prisma": "6.18.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "allowScripts": {
    "@prisma/client@6.18.0": true,
    "@prisma/engines@6.18.0": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true,
    "prisma@6.18.0": true,
    "sharp@0.34.5": true
  }
}
