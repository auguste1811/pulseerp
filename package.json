{
  "name": "pulseerp",
  "version": "3.8.1",
  "private": true,
  "engines": {
    "node": ">=22 <27",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "setup": "npm run db:migrate && npm run db:seed",
    "auth:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('base64url'))\"",
    "vercel-build": "prisma generate && next build",
    "platform:promote": "tsx scripts/promote-platform-admin.ts",
    "platform:create-admin": "tsx scripts/create-platform-admin.ts"
  },
  "dependencies": {
    "bcryptjs": "3.0.2",
    "jose": "6.1.0",
    "next": "16.2.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "4.1.12",
    "pg": "8.16.3",
    "@prisma/client": "6.18.0",
    "next-auth": "5.0.0-beta.30",
    "@auth/prisma-adapter": "2.10.0",
    "stripe": "22.3.2"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "@types/pg": "8.15.5",
    "prisma": "6.18.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "packageManager": "npm@10.9.2"
}
